# =============================================
# AI Storyboard Pro v2.2 - 环境配置
# =============================================
# 复制此文件为 .env 并填入你的配置
# cp .env.example .env

# =============================================
# 图像生成后端 (二选一)
# =============================================
# canghe  - 苍何 API 云端生成 (需要 API Key)
# comfyui - 本地 ComfyUI 生成 (需要本地 ComfyUI 服务)
IMAGE_BACKEND=canghe

# =============================================
# 苍何 API 配置 (IMAGE_BACKEND=canghe 时必需)
# =============================================
# 苍何 API 密钥 - 从 https://api.canghe.ai 获取
CANGHE_API_KEY=your_api_key_here
CANGHE_API_BASE_URL=https://api.canghe.ai

# SeedreamBest 同款 MuleRouter/Wan 模型
# 图像默认 wan2.6-t2i；视频默认 wan2.7-i2v-spicy
MULEROUTER_API_KEY=your_mulerouter_api_key_here
MULEROUTER_BASE_URL=https://api.mulerouter.ai
SEEDREAMBEST_IMAGE_PROVIDER_BASE_URL=https://api.mulerouter.ai
SEEDREAMBEST_IMAGE_PROVIDER_API_KEY=your_mulerouter_api_key_here
SEEDREAMBEST_IMAGE_PROVIDER_MODEL=wan2.6-t2i
SEEDREAMBEST_VIDEO_PROVIDER_BASE_URL=https://api.mulerouter.ai
SEEDREAMBEST_VIDEO_PROVIDER_API_KEY=your_mulerouter_api_key_here
SEEDREAMBEST_VIDEO_PROVIDER_MODEL=wan2.7-i2v-spicy

# 文字生成模型：Qwen OpenAI-compatible 服务
LLM_PROVIDER=Qwen (OpenAI兼容)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=http://32.196.46.122:8000/v1
QWEN_LLM_MODEL=/home/ubuntu/models/Qwen3.6-35B-A3B-uncensored-heretic

# =============================================
# ComfyUI 配置 (IMAGE_BACKEND=comfyui 时必需)
# =============================================
# 是否启用 ComfyUI
COMFYUI_ENABLED=false

# ComfyUI 服务地址
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188

# 自定义工作流目录 (可选)
# COMFYUI_WORKFLOW_DIR=workflows

# 指定工作流文件 (可选)
# COMFYUI_WORKFLOW_FILE=path/to/workflow.json

# 指定模型 (可选，留空自动检测)
# COMFYUI_MODEL=sd_xl_base_1.0

# =============================================
# 服务器配置
# =============================================
# Gradio UI 端口
GRADIO_PORT=7861
GRADIO_HOST=0.0.0.0

# FastAPI 端口
API_PORT=8000
API_HOST=0.0.0.0

# =============================================
# CORS 配置
# =============================================
# 允许的跨域源 (逗号分隔)
# 开发环境用 *，生产环境应限制具体域名
CORS_ORIGINS=*

# =============================================
# 文件上传配置
# =============================================
# 最大上传大小 (MB)
MAX_UPLOAD_SIZE_MB=50

# 允许的文件扩展名 (逗号分隔)
ALLOWED_EXTENSIONS=.pdf,.docx,.doc,.md,.markdown,.html,.htm,.txt,.jpg,.jpeg,.png

# =============================================
# Ollama 配置 (可选 - 用于本地 AI 模型)
# =============================================
# OLLAMA_HOST=localhost
# OLLAMA_PORT=11434

# =============================================
# 调试模式
# =============================================
# 启用详细日志
DEBUG=false
